{
  "id": "ds_payer_list",
  "name": "납부자 목록",
  "type": "DB_QUERY",
  "query": "SELECT p.payer_no,\n  a.bank_code, a.account_no,\n  a.holder_name, a.birth_biz_no\nFROM tb_payer p\nJOIN tb_payer_account a\n  ON p.payer_id = a.payer_id\nWHERE p.inst_id = :instId\n  AND p.status = 'ACTIVE'",
  "params": [
    { "name": "instId", "source": "context.institutionId" }
  ],
  "stub": {
    "scenarios": {
      "default": [
        { "payer_no": "PAY00000001", "bank_code": "KB", "account_no": "12345678901234", "holder_name": "홍길동", "birth_biz_no": "1990-01-15", "amount": 50000 },
        { "payer_no": "PAY00000002", "bank_code": "088", "account_no": "98765432109876", "holder_name": "김영희", "birth_biz_no": "1985-07-22", "amount": 75000 },
        { "payer_no": "PAY00000003", "bank_code": "NH", "account_no": "5678901234", "holder_name": "이철수", "birth_biz_no": "123-45-67890", "amount": 0 }
      ],
      "empty": []
    }
  }
}
